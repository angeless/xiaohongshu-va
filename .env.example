# ============================================
# Video Copy Analyzer - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# --- AI Analysis Provider (required: at least one) ---
# Primary provider: anthropic | openai | kimi | qwen | minimax | auto
ANALYSIS_PROVIDER=anthropic

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# OpenAI (GPT)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Kimi (Moonshot)
# KIMI_API_KEY=your_kimi_api_key_here
# KIMI_MODEL=moonshot-v1-8k
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# Qwen (Alibaba)
# QWEN_API_KEY=your_qwen_api_key_here
# QWEN_MODEL=qwen-plus
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# MiniMax
# MINIMAX_API_KEY=your_minimax_api_key_here
# MINIMAX_MODEL=MiniMax-Text-01
# MINIMAX_BASE_URL=https://api.minimax.chat/v1

# Fallback chain (comma-separated, tried in order when primary fails)
# ANALYSIS_FALLBACKS=openai,kimi,qwen,minimax

# Allow local heuristic fallback when ALL providers fail (1=yes, 0=no)
ALLOW_LOCAL_FALLBACK=1

# --- Notion Integration (optional, for Step 4 upload) ---
# NOTION_TOKEN=your_notion_integration_token_here
# NOTION_DATABASE_ID=your_32char_database_id_here

# --- Image Upload (optional, for cover/frame upload to Notion) ---
# IMGBB_API_KEY=your_imgbb_api_key_here

# --- Feishu / Lark (optional) ---
# FEISHU_APP_ID=your_feishu_app_id_here
# FEISHU_APP_SECRET=your_feishu_app_secret_here
# FEISHU_APP_TOKEN=your_feishu_app_token_here
# FEISHU_TABLE_ID=your_feishu_table_id_here

# --- Persona (optional, defaults to persona.json in project root) ---
# PERSONA_FILE=persona.json

# --- Scraping Behavior ---
# Max seconds to wait for manual login (default: 300)
LOGIN_WAIT_SECONDS=300
# Require login before scraping (1=strict, 0=relaxed)
STRICT_LOGIN_REQUIRED=1
# Max items when scraping a creator's profile page
PROFILE_MAX_ITEMS=10

# --- Whisper (only used as fallback if FunASR unavailable) ---
# WHISPER_MODEL=medium
